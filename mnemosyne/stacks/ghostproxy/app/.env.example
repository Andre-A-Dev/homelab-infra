# ~/stacks/ghostproxy/.env

# Ghost URL (kein trailing slash)
GHOST_URL=https://blog.yourdomain.dedyn.io

# Ghost Admin API Key (Settings → Integrations → ProxyTool → Admin API Key)
# Format: id:secret
GHOST_API_KEY=dein_key_hier

# Interne E-Mail-Domain für Proxy-Accounts (nie real verwendet)
PROXY_EMAIL_DOMAIN=ghostproxy.internal

# Max. Upload-Größe in MB
UPLOAD_MAX_MB=5
