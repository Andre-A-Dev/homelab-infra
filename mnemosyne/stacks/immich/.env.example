# Immich version — "release" always pulls the latest stable
IMMICH_VERSION=release

# Upload location on host (bind mount — backed up by backup-services.sh)
UPLOAD_LOCATION=/mnt/codex/immich/upload

# PostgreSQL data directory
DB_DATA_LOCATION=/mnt/codex/immich/db

# PostgreSQL credentials — change before first start
DB_USERNAME=immich
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE_NAME=immich

# Connection strings — must match the credentials above
# Host must be "database" — this matches the Docker Compose service name (= DNS hostname)
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@database/${DB_DATABASE_NAME}
REDIS_URL=redis://redis:6379
POSTGRES_DB=immich
POSTGRES_USER=immich
