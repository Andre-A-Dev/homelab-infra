# -- Vault ----------------------------------------------------------------

vault.home {
  tls internal

  reverse_proxy vaultwarden:80 {
    header_up X-Real-IP {remote_host}
  }
}

# -- Nextcloud ------------------------------------------------------------

cloud.yourdomain.dedyn.io {
  header Strict-Transport-Security "max-age=15552000; includeSubDomains"

  # Handle well-known DAV redirects directly in Caddy (before Apache sees them)
  handle /.well-known/carddav {
    redir https://cloud.yourdomain.dedyn.io/remote.php/dav 301
  }
  handle /.well-known/caldav {
    redir https://cloud.yourdomain.dedyn.io/remote.php/dav 301
  }

  # Forward push endpoint to notify_push service
  handle /push/* {
    reverse_proxy notify_push:7867
  }

  # All other requests go to Nextcloud
  handle {
    reverse_proxy nextcloud:80 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-Proto {scheme}
      header_up Host {host}
    }
  }
}

# -- Git ------------------------------------------------------------------

git.home {
  tls internal
  reverse_proxy gitea:3000
}

# -- Syncthing ------------------------------------------------------------

syncthing.home {
  tls internal
  reverse_proxy https://192.168.1.10:8384 {
    transport http {
      tls_insecure_skip_verify
    }
  }
}

