# ntfy configuration
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=mnemosyne-jobiris
# NTFY_TOKEN=                  # optional, for self-hosted ntfy with auth

# Board (web UI)
JOBIRIS_BOARD_PORT=8042

# Defaults already match the container layout (code mounted at /app,
# /mnt/vault/jobiris mounted 1:1) - only set these if you change the
# volume mounts in docker-compose.yml.
# JOBIRIS_CONFIG=/app/search-profiles.yaml
# JOBIRIS_DB=/mnt/vault/jobiris/seen_jobs.db
# JOBIRIS_LOG_FILE=/mnt/vault/jobiris/jobiris.log
