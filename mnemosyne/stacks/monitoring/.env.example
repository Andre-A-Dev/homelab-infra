# -- Grafana -----------------------------------------------------------------------

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password
GF_SERVER_DOMAIN=grafana.home
GF_SERVER_ROOT_URL=https://grafana.home

# -- Nextcloud ---------------------------------------------------------------------

NEXTCLOUD_USERNAME=your-nextcloud-user
NEXTCLOUD_PASSWORD=your-nextcloud-app-password
NEXTCLOUD_SERVER=https://cloud.yourdomain.dedyn.io

# -- Netatmo -----------------------------------------------------------------------

NETATMO_CLIENT_ID=your-client-id
NETATMO_CLIENT_SECRET=your-client-secret

# -- Fritz!Box ---------------------------------------------------------------------

FRITZ_HOSTNAME=fritz.box
FRITZ_USERNAME=your-username
FRITZ_PASSWORD=your-password
FRITZ_LISTEN_ADDRESS=0.0.0.0

# -- Tado --------------------------------------------------------------------------

TADO_TOKEN_PASSPHRASE=your-passphrase

# -- Meross ------------------------------------------------------------------------

MEROSS_API_URL=https://iotx-eu.meross.com
MEROSS_EMAIL_1=your-email@example.com
MEROSS_PASSWORD_1=your-meross-password
MEROSS_ALIAS_1=your-device-alias
MEROSS_EMAIL_2=your-email@example.com
MEROSS_PASSWORD_2=your-meross-password
MEROSS_ALIAS_2=your-device-alias
MEROSS_DEVICE_NAMES=device1,device2

# -- Shelly ------------------------------------------------------------------------

# Power plugs (Gen1/Gen2): "name:host:gen,..."
SHELLY_DEVICES=Plug-Name:192.168.178.XX:2
# H&T Gen3 sensors: "name;host,..."
SHELLY_HT_DEVICES=HT-Keller;192.168.1.x
# BLU H&T via gateway KVS: "name;gateway_host;mac,..."
SHELLY_BLU_DEVICES=BLU-Keller;192.168.1.x;c0:2c:ed:77:df:12
POLL_INTERVAL=15
POLL_INTERVAL_SHELLY=15
RECONNECT_INTERVAL=30
EXPORTER_PORT=9100

# -- ntfy (Alertmanager notifications) --------------------------------------------

NTFY_PUMP_CRITICAL=Pump-Critical-yourtoken
NTFY_PUMP_WARNING=Pump-Warning-yourtoken
NTFY_MNEMOSYNE_CRITICAL=Mnemosyne-Critical-yourtoken
NTFY_MNEMOSYNE_WARNING=Mnemosyne-Warning-yourtoken

# -- pump-alerts webhook receiver --------------------------------------------

# Random string used to verify Gitea webhook payloads (set same in Gitea)
# openssl rand -hex 32
PUMP_WEBHOOK_SECRET=

# Gitea API token for reading pump-alerts repo (create in Gitea user settings)
PUMP_GITEA_TOKEN=

# Gitea repo path, e.g. username/pump-alerts
PUMP_GITEA_REPO=username/pump-alerts

# -- Midea Portasplit -------------------------------------------------------------
MIDEA_IP=192.168.178.XX
MIDEA_ID=
MIDEA_TOKEN=
MIDEA_KEY=
MIDEA_DEVICE_NAME=portasplit
MIDEA_ACCOUNT=home