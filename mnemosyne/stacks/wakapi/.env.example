# Wakapi configuration
# Copy to .env and encrypt with: sops-edit.sh wakapi/.env

# Database: SQLite is sufficient for solo use
WAKAPI_DB_TYPE=sqlite3
WAKAPI_DB_PATH=/data/wakapi.db

# Security
WAKAPI_PASSWORD_SALT=change_me_random_string_32chars

# Server
WAKAPI_LISTEN_V4=0.0.0.0
WAKAPI_PORT=3000
WAKAPI_PUBLIC_URL=https://wakapi.home

# Registration: disabled after initial user creation
WAKAPI_ALLOW_SIGNUP=true

# Optional: weekly email digest (leave empty to disable)
WAKAPI_MAIL_ENABLED=false

# Disable update checks (no outbound phone-home)
WAKAPI_DISABLE_UPDATES=true